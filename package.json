{
  "name": "mahiro-mcp-memory-layer",
  "version": "0.0.0",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "main": "./src/features/opencode-plugin/index.ts",
  "exports": {
    ".": "./src/features/opencode-plugin/index.ts"
  },
  "files": [
    "src/config",
    "src/features/memory/constants.ts",
    "src/features/memory/core",
    "src/features/memory/index",
    "src/features/memory/lib",
    "src/features/memory/log",
    "src/features/memory/memory-facade.ts",
    "src/features/memory/memory-service.ts",
    "src/features/memory/observability",
    "src/features/memory/retrieval",
    "src/features/memory/schemas.ts",
    "src/features/memory/types.ts",
    "src/features/opencode-plugin",
    "README.md",
    "AGENTS.md",
    "MCP_USAGE.md",
    "CONTINUITY_DEBUGGING.md",
    "ARCHITECTURE_BOUNDARIES.md",
    "AGENT_NEXT_STEPS.md",
    "package.json"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "eval-retrieval": "tsx src/eval-retrieval.ts",
    "reindex": "tsx src/index.ts --reindex",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests/product-memory-plugin.test.ts tests/opencode-plugin-package.test.ts tests/opencode-plugin-scope-resolution.test.ts"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.22.3",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@opencode-ai/plugin": "^1.4.3",
    "apache-arrow": "^18.1.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "tsx": "^4.20.6",
    "typescript": "~5.9.3",
    "vitest": "^3.2.4"
  }
}
